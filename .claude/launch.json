{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "allstore",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','css':'text/css','js':'text/javascript','png':'image/png','jpg':'image/jpeg','jpeg':'image/jpeg','webp':'image/webp','svg':'image/svg+xml','gif':'image/gif','ico':'image/x-icon','json':'application/json','woff':'font/woff','woff2':'font/woff2','zip':'application/zip'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':q.url.split('?')[0];let fp=p.join('AllStore SITE WEB',decodeURIComponent(u));f.readFile(fp,(e,d)=>{if(e){r.writeHead(404);r.end('Not found');return}let ext=p.extname(fp).slice(1);r.writeHead(200,{'Content-Type':m[ext]||'application/octet-stream'});r.end(d)})}).listen(3000)"],
      "port": 3000
    }
  ]
}
