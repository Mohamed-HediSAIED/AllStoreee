{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull --ff-only 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Synchronisation avec la derniere version du code..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Heure actuelle (Paris): %s\"}}' \"$(TZ='Europe/Paris' date '+%Y-%m-%d %H:%M %Z (%A)')\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
