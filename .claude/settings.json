{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 30,
            "statusMessage": "Sync repo + injection du contexte projet AllStore..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Heure actuelle (Paris): %s\"}}' \"$(TZ='Europe/Paris' date '+%Y-%m-%d %H:%M %Z (%A)')\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
